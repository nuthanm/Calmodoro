{
  "manifest_version": 3,
  "name": "Calmodoro",
  "version": "1.0.0",
  "description": "Pomodoro timer with calming animations and break reminders",
  "permissions": ["storage", "alarms", "notifications", "windows"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_badge_text": ""
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
